# ─── Mode ────────────────────────────────────────────────────────────────────
# true  → Ollama for all AI agents; Replicate for image gen (local dev default)
# false → Gemini 1.5 Flash (Agent A) + GPT-4o mini (B1/B2) + Nano Banana 2 (image gen)
LOCAL_MODE=true

# Override image gen provider regardless of LOCAL_MODE
# Options: nano_banana_2 | replicate
# IMAGE_GEN_PROVIDER=nano_banana_2

# ─── Local Inference (Ollama) ─────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
# Required model: qwen3-vl:30b  (vision + text for all agents)
# Optional model: cogvlm2:10b   (benchmark vs qwen3-vl at Phase 2)

# ─── Cloud AI Providers ───────────────────────────────────────────────────────
OPENAI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
ANTHROPIC_API_KEY=

# ─── Image Generation ─────────────────────────────────────────────────────────
# Primary (LOCAL_MODE=false): Nano Banana 2 uses GOOGLE_GENERATIVE_AI_API_KEY above
# Fallback / local dev:
REPLICATE_API_TOKEN=

# ─── Storage (production only — leave blank for local dev) ───────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
